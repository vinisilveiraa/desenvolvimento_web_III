@model ProjetoEventos.Models.Evento

@{
    ViewData["Title"] = "Detalhes";
}

<div>
    <h4>Evento</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Titulo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Titulo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descricao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descricao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Data_evento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Data_evento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Patrocinador)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Patrocinador.Nome_empresa)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo.Descritivo)
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.EventoId">Editar</a> 
    <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
</div>
