@model IEnumerable<ProjetoEventos.Models.Patrocinador>

@{
    ViewData["Title"] = "Index";
}

<h4>Patrocinadores</h4>

<p>
    <a class="btn btn-primary" asp-action="Create">Novo Patrocinador</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome_empresa)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Website)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome_empresa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Website)
            </td>
            <td>
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.PatrocinadorId">Editar</a> 
                <a class="btn btn-primary" asp-action="Details" asp-route-id="@item.PatrocinadorId">Detalhes</a> 
                <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.PatrocinadorId">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>
