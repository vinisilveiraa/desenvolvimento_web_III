@model IEnumerable<ProjetoEventos.Models.Tipo>

@{
    ViewData["Title"] = "Index";
}

<h4>Tipos de Eventos</h4>

<p>
    <a class="btn btn-primary" asp-action="Create">Novo Tipo</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Descritivo)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Descritivo)
            </td>
                <td>
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.TipoId">Editar</a> 
                <a class="btn btn-primary" asp-action="Details" asp-route-id="@item.TipoId">Detalhes</a>
                <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.TipoId">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>
