@model ProjetoEventos.Models.Tipo

@{
    ViewData["Title"] = "Edit";
}

<h4>Tipo de Evento</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="TipoId" />
            <div class="form-group">
                <label asp-for="Descritivo" class="control-label"></label>
                <input asp-for="Descritivo" class="form-control" />
                <span asp-validation-for="Descritivo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<div>
    
</div>

