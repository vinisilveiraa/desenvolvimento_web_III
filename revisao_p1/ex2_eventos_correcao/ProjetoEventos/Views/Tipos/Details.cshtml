@model ProjetoEventos.Models.Tipo

@{
    ViewData["Title"] = "Detalhes";
}

<div>
    <h4>Tipo de Evento</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descritivo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descritivo)
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.TipoId">Edit</a> 
    <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
</div>
