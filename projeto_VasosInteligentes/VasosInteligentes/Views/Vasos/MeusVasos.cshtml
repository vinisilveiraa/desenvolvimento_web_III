@model IEnumerable<VasosInteligentes.Models.Vaso>

@{
	ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
	<a asp-action="Create">Create New</a>
</p>
<table class="table">
	<thead>
		<tr>
			<th>
				@Html.DisplayNameFor(model => model.Nome)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.PlantaId)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Localizacao)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.UltimaLeitura.Temperatura)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.UltimaLeitura.Umidade)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.UltimaLeitura.Luminosidade)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.UltimaLeitura.DataLeitura)
			</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@Html.DisplayFor(modelItem => item.Nome)
				</td>
				<td>
					@item.PlantaList?.FirstOrDefault()?.Nome
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Localizacao)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.UltimaLeitura.Temperatura)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.UltimaLeitura.Umidade)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.UltimaLeitura.Luminosidade)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.UltimaLeitura.DataLeitura.ToLocalTime().ToString("HH:mm:ss"))
				</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
					<a asp-action="Details" asp-route-id="@item.Id">Details</a> |
					<a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>
