@model IEnumerable<SistemaAcademico.Models.Curso>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vagas)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vagas)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CursoId" class="btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.CursoId" class="btn-primary">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.CursoId" class="btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
