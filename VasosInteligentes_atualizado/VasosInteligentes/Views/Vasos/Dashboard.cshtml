@using System.Text.Json;
@using VasosInteligentes.ViewModel

@model List<DashboardViewModel>
@{
    ViewData["Title"] = "Dashboard";

    // converte os dados da model em Json
    // colocas as datas no formato ISO
    var nomesJson = JsonSerializer.Serialize(Model.Select(m => m.NomeVaso));
    var manhaJson = JsonSerializer.Serialize(Model.Select(m => m.MediaManha));
    var tardeJson = JsonSerializer.Serialize(Model.Select(m => m.MediaTarde));
    var noiteJson = JsonSerializer.Serialize(Model.Select(m => m.MediaNoite));
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 bg-light">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-muted">Total de Vasos</h6>
                    <h2 class="display-4 text-success fw-bold">@Model.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100 bg-light">
                <div class="card-body d-flex flex-column justify-content-center text-center gap-2">
                    <form method="get" action="@Url.Action("Dashboard", "Vasos")">
                        <button type="submit" name="filter" value="diario" class="btn @(ViewBag.filter == "diario" ? "btn-primary" : "btn-outline-primary")">Diario</button>
                        <button type="submit" name="filter" value="geral" class="btn @(ViewBag.filter == "geral" ? "btn-primary" : "btn-outline-primary")">Geral</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title text-secondary border-bottom pb-2 mb-3">Monitoramento <strong>@(ViewBag.filter == "diario" ? "das Últimas 24 Horas" : "Geral")</strong></h5>

            @if (Model.Any())
            {
                <div id="graficoSensores"></div>
            }
            else
            {
                <div class="alert alert-warning text-center my-4" role="alert">
                    Ainda não há histórico de dados coletados para este vaso nas últimas 24 horas.
                    Certifique-se de que o simulador de sensores está rodando em segundo plano.
                </div>
            }

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    // distribuindo as variaveis

    const vasoNome = @Html.Raw(nomesJson);
    const mediaManha = @Html.Raw(manhaJson);
    const mediaTarde = @Html.Raw(tardeJson);
    const mediaNoite = @Html.Raw(noiteJson);

    if (vasoNome.length !== 0) {
    var options = {
        chart: {
            height: 300,
            type: 'bar',
            stacked: true,
            toolbar: {
                show: true
            }
        },
        plotOptions: {
            bar: {
                horizontal: false,
                borderRadius: 6,
                columnWidth: '20%'
            }
        },
        colors: [ '#008FFB', '#FF9800', '#00C853' ],
        series: [
            {
                name: 'Manhã (6h - 11:59h)',
                data: mediaManha
            },
            {
                name: 'Tarde (12h - 17:59h)',
                data: mediaTarde
            },
            {
                name: 'Noite (18h - 00:00h)',
                data: mediaNoite
            }
        ],
        xaxis: {
            categories: vasoNome,
            title: {
                text: 'Vasos'
            },
            labels: {
                style: {
                    colors: '#6c757d'
                }
            }
        },
        yaxis: {
            max: 100,
            title: {
                text: 'Média de Luminosidade'
            },
            labels: {
                formatter: function (value) {
                    return value.toFixed(0);
                },
                style: {
                    colors: '#6c757d'
                }
            }
        },
        dataLabels: {
            enabled: false
        },
        legend: {
            position: 'top'
        },
        grid: {
            borderColor: '#e7e7e7',
            row: {
                colors: ['#f3f3f3', 'transparent'],
                opacity: 0.5
            }
        }
    };


    // Renderiza o gráfico na tela
    var chart = new ApexCharts(document.querySelector("#graficoSensores"), options);
    chart.render();
    }
</script>